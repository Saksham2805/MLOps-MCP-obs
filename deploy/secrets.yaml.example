apiVersion: v1
kind: Secret
metadata:
  name: llm-obs-secrets
  namespace: llm-obs
type: Opaque
data:
  # All values are base64-encoded. Replace with your actual credentials.
  # Example encoding: echo -n 'myvalue' | base64
  #
  # POSTGRES_USER: the TimescaleDB username (e.g. obs_user)
  POSTGRES_USER: b2JzX3VzZXI=
  #
  # POSTGRES_PASSWORD: the TimescaleDB password
  POSTGRES_PASSWORD: Y2hhbmdlbWU=
  #
  # TIMESCALEDB_URL: full DSN connection string
  # e.g. postgresql://obs_user:changeme@timescaledb-svc.llm-obs.svc.cluster.local:5432/llm_obs
  TIMESCALEDB_URL: cG9zdGdyZXNxbDovL29ic191c2VyOmNoYW5nZW1lQHRpbWVzY2FsZWRiLXN2Yy5sbG0tb2JzLnN2Yy5jbHVzdGVyLmxvY2FsOjU0MzIvbGxtX29icw==
  #
  # ALERTMANAGER_URL: full URL to Alertmanager API
  # e.g. http://alertmanager.monitoring.svc.cluster.local:9093
  ALERTMANAGER_URL: aHR0cDovL2FsZXJ0bWFuYWdlci5tb25pdG9yaW5nLnN2Yy5jbHVzdGVyLmxvY2FsOjkwOTM=
